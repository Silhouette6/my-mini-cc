# ============================================================
# MiniCC 配置文件
# 复制此文件为 .env 并填入实际值：cp .env.example .env
# ============================================================

# --- LLM 提供者 ---
# 可选值：openai | anthropic | zhipu
LLM_PROVIDER=openai
MODEL_ID=gpt-4o

# 自定义 API 端点（代理、本地模型等），留空则使用官方默认
# API_BASE_URL=https://your-proxy.com/v1

# 智谱 Coding Plan 必须使用专属端点（代码会自动补全 /chat/completions）：
# API_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4

# LLM API 请求超时（秒），默认 30
# LLM_REQUEST_TIMEOUT=30

# --- API Keys（按所选提供者填写一个即可）---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# ZHIPUAI_API_KEY=...

# --- 路径 ---
# WORKDIR=.
# TASKS_DIR=.tasks
# SKILLS_DIR=skills
# TRANSCRIPT_DIR=.transcripts

# --- 记忆压缩 ---
# SOFT_TOKEN_LIMIT=40000
# HARD_TOKEN_LIMIT=80000
# MEMORY_TOOL_RETAIN=5       # Layer 1 保留的普通工具消息条数
# MEMORY_SUBAGENT_RETAIN=10  # Layer 1 保留的 subagent 返回条数
# MEMORY_LOAD_SKILL_RETAIN=10  # Layer 1 保留的 load_skill 返回条数

# --- Agent 迭代上限 ---
# MAX_ITERATIONS=30
# WORKER_EXPLORE_MAX_ITER=15
# WORKER_CODER_MAX_ITER=30
# WORKER_SHELL_MAX_ITER=10

# --- REPL 进度展示 ---
# PROGRESS_SINGLE_LINE=true   # true: 单行覆盖（不刷屏）；false: 每状态换行持续输出
# PROGRESS_STATUS_BASH_MAX=48      # bash 命令在状态栏显示的最大字符数
# PROGRESS_STATUS_READ_FILE_MAX=40 # read_file 路径在状态栏显示的最大字符数
# PROGRESS_STATUS_EDIT_PATH_MAX=35 # edit_file/write_file 路径在状态栏显示的最大字符数
# PROGRESS_STATUS_GENERIC_MAX=40   # 其他工具参数在状态栏显示的最大字符数
# PROGRESS_STATUS_TASK_MAX=48      # todo_write 等 task 工具在状态栏显示的最大字符数
# PROGRESS_STATUS_TOOL_RESULT_MAX=120  # 工具返回结果预览的最大字符数

# --- 调试 ---
# DEBUG_LOG_ENABLED=false   # 开启调试日志，记录每轮上下文/模型/工具到 log/
# DEBUG_LOG_DIR=log

# --- 安全 ---
# COMMAND_TIMEOUT=120
